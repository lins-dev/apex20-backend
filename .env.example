# Backend Environment Variables (Local Development) 🐹

# Database
DATABASE_URL=postgres://apex20:password@apex20-db:5432/apex20?sslmode=disable

# Redis
REDIS_URL=redis://apex20-cache:6379

# Server Configuration
PORT=8787
NODE_ENV=development

# JWT RS256 — chave privada RSA em formato PKCS8 PEM (gere com: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 | openssl pkcs8 -topk8 -nocrypt)
JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"
